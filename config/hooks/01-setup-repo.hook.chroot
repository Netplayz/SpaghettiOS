#!/bin/bash
# SpaghettiOS: Add custom repository to the live system

set -e

REPO_URL="http://mousecorp.xyz/spaghettios/repo"
REPO_KEY="/usr/share/keyrings/spaghettos-archive-keyring.gpg"

cat > /etc/apt/sources.list.d/spaghettios.list << EOF
deb [signed-by=${REPO_KEY}] ${REPO_URL} al-dente main
deb-src [signed-by=${REPO_KEY}] ${REPO_URL} al-dente main
EOF

# Ensure the key is trusted (the .list already uses signed-by)
apt-get update
