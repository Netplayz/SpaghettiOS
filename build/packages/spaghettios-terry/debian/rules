#!/usr/bin/make -f

%:
	dh $@

override_dh_auto_configure:
	# no configure needed

override_dh_auto_build:
	gcc -o src/terrydavis src/main.c \
	    $(pkg-config --cflags --libs gtk+-3.0) \
	    -Wall -Wextra -O2

override_dh_auto_install:
	mkdir -p $(CURDIR)/debian/spaghettios-terry/usr/bin
	cp src/terrydavis $(CURDIR)/debian/spaghettios-terry/usr/bin/
	mkdir -p $(CURDIR)/debian/spaghettios-terry/usr/share/spaghettios-terry
	mkdir -p $(CURDIR)/debian/spaghettios-terry/usr/share/applications
	cp debian/spaghettios-terry.desktop $(CURDIR)/debian/spaghettios-terry/usr/share/applications/
	# Copy photo if present
	if [ -f data/terry.jpg ]; then \
	    cp data/terry.jpg $(CURDIR)/debian/spaghettios-terry/usr/share/spaghettios-terry/; \
	fi
	if [ -f data/terry.png ]; then \
	    cp data/terry.png $(CURDIR)/debian/spaghettios-terry/usr/share/spaghettios-terry/; \
	fi

override_dh_auto_test:
	# no tests
